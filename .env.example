# OpenRouter (https://openrouter.ai/) — create a key in your account dashboard.
# Copy this file to `.env.local` and fill in the value (Next.js loads `.env.local` automatically).
OPENROUTER_API_KEY=

# Optional: override the default model (default is openrouter/aurora-alpha).
# OPENROUTER_MODEL=openrouter/aurora-alpha

# Optional: OpenRouter attribution headers (recommended for public apps).
# OPENROUTER_HTTP_REFERER=https://yoursite.com
# OPENROUTER_APP_TITLE=Auto Cards
